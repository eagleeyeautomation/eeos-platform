{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/serverless-app.js"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api?path=$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/((?!api(?:/|$)).*)",
      "dest": "/index.html"
    }
  ]
}
