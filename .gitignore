# Dependencies
**/node_modules
node_modules/
.pnpm-store/
jspm_packages/
bower_components
web_modules/

# Build outputs
dist/
build/
build/Release
*.dist
out
.output

# Environment variables
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.vscode/
.vscode-test
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage
lib-cov
coverage/
coverage
*.lcov
.nyc_output

# Grunt / Bower
.grunt
.lock-wscript

# TypeScript cache
*.tsbuildinfo

